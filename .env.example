; LifeMed CRM Environment Configuration
; Copy this file to .env and fill in your values

; Database
DB_HOST=localhost
DB_NAME=lifemed
DB_USER=root
DB_PASS=

; Telegram Bot
TG_BOT_TOKEN=your_bot_token_here
TG_ADMIN_CHAT_ID=your_chat_id_here

; Debug mode (set to true for development)
APP_DEBUG=false
